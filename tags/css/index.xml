    <item>
      <title>CSS Selectors</title>
      <link>https://pauliusuk.github.io/posts/2024/css-selectors/</link>
      <pubDate>Thu, 28 Mar 2024 20:41:34 +0000</pubDate>
      <guid>https://pauliusuk.github.io/posts/2024/css-selectors/</guid>
      <description>&lt;img src=&#34;https://skillicons.dev/icons?i=css&#34; alt=&#34;Icon&#34; style=&#34;width:50px;&#34;&gt;&#xA;&#xA;&#xA;&#xA;&lt;div class=&#34;searchable-table&#34;&gt;&#xD;&#xA;    &lt;input type=&#34;text&#34; class=&#34;search-input&#34; placeholder=&#34;Search...&#34;&gt;&#xD;&#xA;&lt;table&gt;&#xA;  &lt;thead&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;th&gt;Selector&lt;/th&gt;&#xA;          &lt;th&gt;Example&lt;/th&gt;&#xA;          &lt;th&gt;Example description&lt;/th&gt;&#xA;      &lt;/tr&gt;&#xA;  &lt;/thead&gt;&#xA;  &lt;tbody&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td&gt;&lt;strong&gt;Pseudo-classes&lt;/strong&gt;&lt;/td&gt;&#xA;          &lt;td&gt;&lt;/td&gt;&#xA;          &lt;td&gt;&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td&gt;&lt;code&gt;:active&lt;/code&gt;&lt;/td&gt;&#xA;          &lt;td&gt;a:active&lt;/td&gt;&#xA;          &lt;td&gt;Selects the active link&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td&gt;&lt;code&gt;:checked&lt;/code&gt;&lt;/td&gt;&#xA;          &lt;td&gt;input:checked&lt;/td&gt;&#xA;          &lt;td&gt;Selects every checked &amp;lt;input&amp;gt; element&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td&gt;&lt;code&gt;:default&lt;/code&gt;&lt;/td&gt;&#xA;          &lt;td&gt;input:default&lt;/td&gt;&#xA;          &lt;td&gt;Selects the default &amp;lt;input&amp;gt; element&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td&gt;&lt;code&gt;:disabled&lt;/code&gt;&lt;/td&gt;&#xA;          &lt;td&gt;input:disabled&lt;/td&gt;&#xA;          &lt;td&gt;Selects every disabled &amp;lt;input&amp;gt; element&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td&gt;&lt;code&gt;:empty&lt;/code&gt;&lt;/td&gt;&#xA;          &lt;td&gt;p:empty&lt;/td&gt;&#xA;          &lt;td&gt;Selects every &amp;lt;p&amp;gt; element that has no children (including text nodes)&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td&gt;&lt;code&gt;:enabled&lt;/code&gt;&lt;/td&gt;&#xA;          &lt;td&gt;input:enabled&lt;/td&gt;&#xA;          &lt;td&gt;Selects every enabled &amp;lt;input&amp;gt; element&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td&gt;&lt;code&gt;:first-child&lt;/code&gt;&lt;/td&gt;&#xA;          &lt;td&gt;p:first-child&lt;/td&gt;&#xA;          &lt;td&gt;Selects every &amp;lt;p&amp;gt; element that is the first child of its parent&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td&gt;&lt;code&gt;:first-of-type&lt;/code&gt;&lt;/td&gt;&#xA;          &lt;td&gt;p:first-of-type&lt;/td&gt;&#xA;          &lt;td&gt;Selects every &amp;lt;p&amp;gt; element that is the first &amp;lt;p&amp;gt; element of its parent&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td&gt;&lt;code&gt;:focus&lt;/code&gt;&lt;/td&gt;&#xA;          &lt;td&gt;input:focus&lt;/td&gt;&#xA;          &lt;td&gt;Selects the input element which has focus&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td&gt;&lt;code&gt;:fullscreen&lt;/code&gt;&lt;/td&gt;&#xA;          &lt;td&gt;:fullscreen&lt;/td&gt;&#xA;          &lt;td&gt;Selects the element that is in full-screen mode&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td&gt;&lt;code&gt;:hover&lt;/code&gt;&lt;/td&gt;&#xA;          &lt;td&gt;a:hover&lt;/td&gt;&#xA;          &lt;td&gt;Selects links on mouse over&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td&gt;&lt;code&gt;:in-range&lt;/code&gt;&lt;/td&gt;&#xA;          &lt;td&gt;input:in-range&lt;/td&gt;&#xA;          &lt;td&gt;Selects input elements with a value within a specified range&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td&gt;&lt;code&gt;:indeterminate&lt;/code&gt;&lt;/td&gt;&#xA;          &lt;td&gt;input:indeterminate&lt;/td&gt;&#xA;          &lt;td&gt;Selects input elements that are in an indeterminate state&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td&gt;&lt;code&gt;:invalid&lt;/code&gt;&lt;/td&gt;&#xA;          &lt;td&gt;input:invalid&lt;/td&gt;&#xA;          &lt;td&gt;Selects all input elements with an invalid value&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td&gt;&lt;code&gt;:lang(language)&lt;/code&gt;&lt;/td&gt;&#xA;          &lt;td&gt;p:lang(it)&lt;/td&gt;&#xA;          &lt;td&gt;Selects every &amp;lt;p&amp;gt; element with a lang attribute equal to &amp;ldquo;it&amp;rdquo; (Italian)&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td&gt;&lt;code&gt;:last-child&lt;/code&gt;&lt;/td&gt;&#xA;          &lt;td&gt;p:last-child&lt;/td&gt;&#xA;          &lt;td&gt;Selects every &amp;lt;p&amp;gt; element that is the last child of its parent&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td&gt;&lt;code&gt;:last-of-type&lt;/code&gt;&lt;/td&gt;&#xA;          &lt;td&gt;p:last-of-type&lt;/td&gt;&#xA;          &lt;td&gt;Selects every &amp;lt;p&amp;gt; element that is the last &amp;lt;p&amp;gt; element of its parent&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td&gt;&lt;code&gt;:link&lt;/code&gt;&lt;/td&gt;&#xA;          &lt;td&gt;a:link&lt;/td&gt;&#xA;          &lt;td&gt;Selects all unvisited links&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td&gt;&lt;code&gt;:not(selector)&lt;/code&gt;&lt;/td&gt;&#xA;          &lt;td&gt;:not(p)&lt;/td&gt;&#xA;          &lt;td&gt;Selects every element that is not a &amp;lt;p&amp;gt; element&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td&gt;&lt;code&gt;:nth-child(n)&lt;/code&gt;&lt;/td&gt;&#xA;          &lt;td&gt;p:nth-child(2)&lt;/td&gt;&#xA;          &lt;td&gt;Selects every &amp;lt;p&amp;gt; element that is the second child of its parent&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td&gt;&lt;code&gt;:nth-last-child(n)&lt;/code&gt;&lt;/td&gt;&#xA;          &lt;td&gt;p:nth-last-child(2)&lt;/td&gt;&#xA;          &lt;td&gt;Selects every &amp;lt;p&amp;gt; element that is the second child of its parent, counting from the last child&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td&gt;&lt;code&gt;:nth-last-of-type(n)&lt;/code&gt;&lt;/td&gt;&#xA;          &lt;td&gt;p:nth-last-of-type(2)&lt;/td&gt;&#xA;          &lt;td&gt;Selects every &amp;lt;p&amp;gt; element that is the second &amp;lt;p&amp;gt; element of its parent, counting from the last child&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td&gt;&lt;code&gt;:nth-of-type(n)&lt;/code&gt;&lt;/td&gt;&#xA;          &lt;td&gt;p:nth-of-type(2)&lt;/td&gt;&#xA;          &lt;td&gt;Selects every &amp;lt;p&amp;gt; element that is the second &amp;lt;p&amp;gt; element of its parent&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td&gt;&lt;code&gt;:only-child&lt;/code&gt;&lt;/td&gt;&#xA;          &lt;td&gt;p:only-child&lt;/td&gt;&#xA;          &lt;td&gt;Selects every &amp;lt;p&amp;gt; element that is the only child of its parent&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td&gt;&lt;code&gt;:only-of-type&lt;/code&gt;&lt;/td&gt;&#xA;          &lt;td&gt;p:only-of-type&lt;/td&gt;&#xA;          &lt;td&gt;Selects every &amp;lt;p&amp;gt; element that is the only &amp;lt;p&amp;gt; element of its parent&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td&gt;&lt;code&gt;:optional&lt;/code&gt;&lt;/td&gt;&#xA;          &lt;td&gt;input:optional&lt;/td&gt;&#xA;          &lt;td&gt;Selects input elements with no &amp;ldquo;required&amp;rdquo; attribute&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td&gt;&lt;code&gt;:out-of-range&lt;/code&gt;&lt;/td&gt;&#xA;          &lt;td&gt;input:out-of-range&lt;/td&gt;&#xA;          &lt;td&gt;Selects input elements with a value outside a specified range&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td&gt;&lt;code&gt;:read-only&lt;/code&gt;&lt;/td&gt;&#xA;          &lt;td&gt;input:read-only&lt;/td&gt;&#xA;          &lt;td&gt;Selects input elements with the &amp;ldquo;readonly&amp;rdquo; attribute specified&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td&gt;&lt;code&gt;:read-write&lt;/code&gt;&lt;/td&gt;&#xA;          &lt;td&gt;input:read-write&lt;/td&gt;&#xA;          &lt;td&gt;Selects input elements with the &amp;ldquo;readonly&amp;rdquo; attribute NOT specified&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td&gt;&lt;code&gt;:required&lt;/code&gt;&lt;/td&gt;&#xA;          &lt;td&gt;input:required&lt;/td&gt;&#xA;          &lt;td&gt;Selects input elements with the &amp;ldquo;required&amp;rdquo; attribute specified&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td&gt;&lt;code&gt;:root&lt;/code&gt;&lt;/td&gt;&#xA;          &lt;td&gt;:root&lt;/td&gt;&#xA;          &lt;td&gt;Selects the document&amp;rsquo;s root element&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td&gt;&lt;code&gt;:target&lt;/code&gt;&lt;/td&gt;&#xA;          &lt;td&gt;#news:target&lt;/td&gt;&#xA;          &lt;td&gt;Selects the current active #news element (clicked on a URL containing that anchor name)&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td&gt;&lt;code&gt;:valid&lt;/code&gt;&lt;/td&gt;&#xA;          &lt;td&gt;input:valid&lt;/td&gt;&#xA;          &lt;td&gt;Selects all input elements with a valid value&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td&gt;&lt;code&gt;:visited&lt;/code&gt;&lt;/td&gt;&#xA;          &lt;td&gt;a:visited&lt;/td&gt;&#xA;          &lt;td&gt;Selects all visited links&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td&gt;&lt;strong&gt;Classes and IDs&lt;/strong&gt;&lt;/td&gt;&#xA;          &lt;td&gt;&lt;/td&gt;&#xA;          &lt;td&gt;&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td&gt;&lt;code&gt;.class&lt;/code&gt;&lt;/td&gt;&#xA;          &lt;td&gt;.intro&lt;/td&gt;&#xA;          &lt;td&gt;Selects all elements with class=&amp;ldquo;intro&amp;rdquo;&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td&gt;&lt;code&gt;.class1.class2&lt;/code&gt;&lt;/td&gt;&#xA;          &lt;td&gt;.name1.name2&lt;/td&gt;&#xA;          &lt;td&gt;Selects all elements with both name1 and name2 set within its class attribute&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td&gt;&lt;code&gt;.class1 .class2&lt;/code&gt;&lt;/td&gt;&#xA;          &lt;td&gt;.name1 .name2&lt;/td&gt;&#xA;          &lt;td&gt;Selects all elements with name2 that is a descendant of an element with name1&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td&gt;&lt;code&gt;#id&lt;/code&gt;&lt;/td&gt;&#xA;          &lt;td&gt;#firstname&lt;/td&gt;&#xA;          &lt;td&gt;Selects the element with id=&amp;ldquo;firstname&amp;rdquo;&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td&gt;&lt;strong&gt;Attribute Selectors&lt;/strong&gt;&lt;/td&gt;&#xA;          &lt;td&gt;&lt;/td&gt;&#xA;          &lt;td&gt;&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td&gt;&lt;code&gt;[attribute]&lt;/code&gt;&lt;/td&gt;&#xA;          &lt;td&gt;[target]&lt;/td&gt;&#xA;          &lt;td&gt;Selects all elements with a target attribute&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td&gt;&lt;code&gt;[attribute=value]&lt;/code&gt;&lt;/td&gt;&#xA;          &lt;td&gt;[target=&amp;quot;_blank&amp;quot;]&lt;/td&gt;&#xA;          &lt;td&gt;Selects all elements with target=&amp;quot;_blank&amp;quot;&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td&gt;&lt;code&gt;[attribute~=value]&lt;/code&gt;&lt;/td&gt;&#xA;          &lt;td&gt;[title~=&amp;ldquo;flower&amp;rdquo;]&lt;/td&gt;&#xA;          &lt;td&gt;Selects all elements with a title attribute containing the word &amp;ldquo;flower&amp;rdquo;&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td&gt;&lt;code&gt;[attribute|=value]&lt;/code&gt;&lt;/td&gt;&#xA;          &lt;td&gt;[lang|=&amp;ldquo;en&amp;rdquo;]&lt;/td&gt;&#xA;          &lt;td&gt;Selects all elements with a lang attribute value equal to &amp;ldquo;en&amp;rdquo; or starting with &amp;ldquo;en-&amp;rdquo;&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td&gt;&lt;code&gt;[attribute^=value]&lt;/code&gt;&lt;/td&gt;&#xA;          &lt;td&gt;a[href^=&amp;ldquo;https&amp;rdquo;]&lt;/td&gt;&#xA;          &lt;td&gt;Selects every &amp;lt;a&amp;gt; element whose href attribute value begins with &amp;ldquo;https&amp;rdquo;&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td&gt;&lt;code&gt;[attribute$=value]&lt;/code&gt;&lt;/td&gt;&#xA;          &lt;td&gt;a[href$=&amp;quot;.pdf&amp;quot;]&lt;/td&gt;&#xA;          &lt;td&gt;Selects every &amp;lt;a&amp;gt; element whose href attribute value ends with &amp;ldquo;.pdf&amp;rdquo;&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td&gt;&lt;strong&gt;Other Selectors&lt;/strong&gt;&lt;/td&gt;&#xA;          &lt;td&gt;&lt;/td&gt;&#xA;          &lt;td&gt;&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td&gt;&lt;code&gt;*&lt;/code&gt;&lt;/td&gt;&#xA;          &lt;td&gt;——————►&lt;/td&gt;&#xA;          &lt;td&gt;Selects all elements&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td&gt;&lt;strong&gt;Descendant Selectors&lt;/strong&gt;&lt;/td&gt;&#xA;          &lt;td&gt;&lt;/td&gt;&#xA;          &lt;td&gt;&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td&gt;&lt;code&gt;p&lt;/code&gt;&lt;/td&gt;&#xA;          &lt;td&gt;——————►&lt;/td&gt;&#xA;          &lt;td&gt;Selects all &amp;lt;p&amp;gt; elements&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td&gt;&lt;code&gt;a[href^=&amp;quot;https&amp;quot;]&lt;/code&gt;&lt;/td&gt;&#xA;          &lt;td&gt;——————►&lt;/td&gt;&#xA;          &lt;td&gt;Selects every &amp;lt;a&amp;gt; element whose href attribute value begins with &amp;ldquo;https&amp;rdquo;&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td&gt;&lt;code&gt;a[href$=&amp;quot;.pdf&amp;quot;]&lt;/code&gt;&lt;/td&gt;&#xA;          &lt;td&gt;——————►&lt;/td&gt;&#xA;          &lt;td&gt;Selects every &amp;lt;a&amp;gt; element whose href attribute value ends with &amp;ldquo;.pdf&amp;rdquo;&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;  &lt;/tbody&gt;&#xA;&lt;/table&gt;&#xA;&lt;/div&gt;&#xD;&#xA;&lt;style&gt;&#xD;&#xA;    .search-container {&#xD;&#xA;        position: relative;&#xD;&#xA;    }&#xD;&#xA;&#xD;&#xA;    .search-input {&#xD;&#xA;        padding: 5px 15px;&#xD;&#xA;        border: none;&#xD;&#xA;        background-color: rgba(255, 255, 255, 0.1);&#xD;&#xA;        color: var(--text);&#xD;&#xA;        font-size: 18px;&#xD;&#xA;        width: 300px;&#xD;&#xA;        box-shadow: 0 0 2px #575757;&#xD;&#xA;        transition: box-shadow 0.3s ease;&#xD;&#xA;    }&#xD;&#xA;&#xD;&#xA;    .search-input:focus {&#xD;&#xA;        outline: none;&#xD;&#xA;    }&#xD;&#xA;&#xD;&#xA;     &#xD;&#xA;    .search-input::placeholder {&#xD;&#xA;        color: rgba(255, 255, 255, 0.5);&#xD;&#xA;    }&#xD;&#xA;&#xD;&#xA;    .search-input:focus::placeholder {&#xD;&#xA;        color: rgba(255, 255, 255, 0.7);&#xD;&#xA;    }&#xD;&#xA;&#xD;&#xA;    .searchable-table .search-input::placeholder {&#xD;&#xA;        color: black;&#xD;&#xA;        font-size: 16px;&#xD;&#xA;    }&#xD;&#xA;    @media (max-width: 632px) {&#xD;&#xA;    .search-input {&#xD;&#xA;         width: 100%;&#xD;&#xA;      }&#xD;&#xA;    }&#xD;&#xA;&lt;/style&gt;&#xD;&#xA;&lt;script&gt;&#xD;&#xA;    document.addEventListener(&#39;DOMContentLoaded&#39;, function() {&#xD;&#xA;        var searchInput = document.querySelector(&#39;.search-input&#39;);&#xD;&#xA;        var tableRows = document.querySelectorAll(&#39;.searchable-table tbody tr&#39;);&#xD;&#xA;        console.log(&#34;Table Rows:&#34;, tableRows);&#xD;&#xA;&#xD;&#xA;        searchInput.addEventListener(&#39;input&#39;, function() {&#xD;&#xA;            var searchText = this.value.trim().toLowerCase();&#xD;&#xA;            console.log(&#34;Search Text:&#34;, searchText);&#xD;&#xA;            &#xD;&#xA;            tableRows.forEach(function(row) {&#xD;&#xA;                var cells = row.querySelectorAll(&#39;td&#39;);&#xD;&#xA;                console.log(&#34;Row Cells:&#34;, cells);&#xD;&#xA;&#xD;&#xA;                var matchFound = Array.from(cells).some(function(cell) {&#xD;&#xA;                    return cell.textContent.toLowerCase().includes(searchText);&#xD;&#xA;                });&#xD;&#xA;                console.log(&#34;Match Found:&#34;, matchFound);&#xD;&#xA;&#xD;&#xA;                row.style.display = matchFound ? &#39;&#39; : &#39;none&#39;;&#xD;&#xA;            });&#xD;&#xA;        });&#xD;&#xA;    });&#xD;&#xA;&lt;/script&gt;&#xD;&#xA;&lt;!-- ## Walkthrough Video --&gt;&#xD;&#xA;&lt;!-- &#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&#xD;&#xA;&lt;div class=&#34;responsive-embed&#34;&gt;&#xD;&#xA;  &lt;div class=&#34;embed video-player&#34; style=&#34;text-align: ;&#34;&gt;&#xD;&#xA;    &lt;iframe class=&#34;youtube-player&#34; type=&#34;text/html&#34; width=&#34;400px&#34; height=&#34;220px&#34;&#xD;&#xA;      src=&#34;https://www.youtube.com/embed/11111111111&#34; allowfullscreen frameborder=&#34;0&#34;&gt;&#xD;&#xA;    &lt;/iframe&gt;&#xD;&#xA;  &lt;/div&gt;&#xD;&#xA;&lt;/div&gt;&#xD;&#xA;&#xD;&#xA;&lt;style&gt;&#xD;&#xA;  .responsive-embed {&#xD;&#xA;    max-width: 100%;&#xD;&#xA;  }&#xD;&#xA;&#xD;&#xA;  .responsive-embed iframe {&#xD;&#xA;    display: block;&#xD;&#xA;    max-width: 100%;&#xD;&#xA;  }&#xD;&#xA;&lt;/style&gt;&#xD;&#xA;&#xD;&#xA; --&gt;</description>
    </item>
